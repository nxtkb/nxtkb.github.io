---
import SiteLayout from '../../layouts/SiteLayout.astro';
---

<SiteLayout title="Products | NXTKB" description="NXTKB split keyboards and accessories.">
  <section class="hero" style="--hero-image: url('/products/ferris-sweep-pro/poster.png')">
    <div class="hero-content">
      <p class="eyebrow">Products</p>
      <h1>Compact keyboards for focused work.</h1>
      <p>Start with Ferris Sweep Pro, the flagship 34-key split keyboard with pointer control, status display, and live keymap editing.</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap product-grid">
      <a class="product-card" href="/products/ferris-sweep-pro/">
        <img src="/products/ferris-sweep-pro/poster.png" alt="Ferris Sweep Pro" />
        <div class="body">
          <h3>Ferris Sweep Pro</h3>
          <p>Flagship split keyboard with Cirque trackpad, e-ink display, dual encoders, and ZMK Studio support.</p>
        </div>
      </a>
      <a class="product-card" href="/products/ferris-sweep/">
        <img src="/products/ferris-sweep/sweep-1.png" alt="Ferris Sweep" />
        <div class="body">
          <h3>Ferris Sweep</h3>
          <p>34-key low-profile wireless split keyboard with hot-swap switches and ZMK Studio support.</p>
        </div>
      </a>
      <a class="product-card" href="/products/magnetic-stand/">
        <img src="/products/magnetic-stand/stand-1.png" alt="Magnetic stand for split keyboards" />
        <div class="body">
          <h3>Magnetic stand</h3>
          <p>A pair of black metal clamp-style stands for stable split-keyboard positioning.</p>
        </div>
      </a>
      <a class="product-card" href="/products/low-profile-keycaps/">
        <img src="/products/low-profile-keycaps/white.png" alt="NXTKB low-profile keycaps" />
        <div class="body">
          <h3>NXTKB low-profile keycaps</h3>
          <p>34-key PBT dye-sub keycap kit for Sweep Pro, available in white and black.</p>
        </div>
      </a>
    </div>
  </section>
</SiteLayout>
